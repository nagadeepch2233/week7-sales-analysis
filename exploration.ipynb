import sys
import os
sys.path.append(os.path.abspath(".."))

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

from sales_analyzer import load_data, clean_data

sns.set(style="whitegrid")
plt.rcParams["figure.figsize"] = (8, 5)

df = load_data("../data/raw/sales_data.csv")

print("First 5 rows:")
display(df.head())

print("\nShape:", df.shape)
print("\nInfo:")
df.info()

print("\nStatistical Summary:")
display(df.describe())

print("\nMissing Values:")
display(df.isnull().sum())

df = clean_data(df)

print("\nCleaned Data Preview:")
display(df.head())

sns.histplot(df["TotalSales"], bins=30, kde=True)
plt.title("Distribution of Total Sales")
plt.xlabel("Total Sales")
plt.ylabel("Frequency")
plt.show()

region_sales = df.groupby("Region")["TotalSales"].sum()

region_sales.plot(kind="bar")
plt.title("Sales by Region")
plt.ylabel("Total Sales")
plt.show()

top_products = (
    df.groupby("Product")["TotalSales"]
    .sum()
    .sort_values(ascending=False)
    .head(5)
)

top_products.plot(kind="bar")
plt.title("Top 5 Products by Sales")
plt.ylabel("Total Sales")
plt.show()

# ---- 9. Monthly Sales Trend ----
df["Month"] = df["OrderDate"].dt.to_period("M")
monthly_sales = df.groupby("Month")["TotalSales"].sum()

monthly_sales.plot()
plt.title("Monthly Sales Trend")
plt.ylabel("Sales")
plt.show()

print("\nExploration Completed Successfully!")
