import sys
import os
sys.path.append(os.path.abspath(".."))

from sales_analyzer import (
    load_data,
    clean_data,
    basic_analysis,
    advanced_analysis,
    create_visualizations,
    generate_reports
)

df = load_data("../data/raw/sales_data.csv")
df = clean_data(df)

total_sales, avg_order_value, top_products, category_sales = basic_analysis(df)

print("\nTotal Sales:", total_sales)
print("Average Order Value:", avg_order_value)

print("\nTop Products:")
display(top_products)

monthly_sales, monthly_growth, customer_ltv, forecast = advanced_analysis(df)

print("\nMonthly Sales:")
display(monthly_sales.head())

print("\nMonthly Growth (%):")
display(monthly_growth.head())

print("\nTop Customers by LTV:")
display(customer_ltv.head())

monthly_growth.plot(title="Monthly Growth Percentage")

forecast.plot(title="3-Month Rolling Forecast")

create_visualizations(monthly_sales, category_sales)

generate_reports(
    total_sales,
    avg_order_value,
    top_products,
    monthly_sales,
    customer_ltv
)

print("\nFull Analysis Completed Successfully!")
